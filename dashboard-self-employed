    <script>
        // --- Navigation Logic ---
        document.querySelectorAll('.nav-link').forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                // Update active nav state
                document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
                e.currentTarget.classList.add('active');
                
                // Show target view
                const targetId = e.currentTarget.getAttribute('data-target');
                document.querySelectorAll('.view-section').forEach(view => {
                    view.classList.add('hidden');
                    view.classList.remove('fade-in');
                });
                const targetView = document.getElementById(targetId);
                targetView.classList.remove('hidden');
                // Trigger reflow for animation
                void targetView.offsetWidth;
                targetView.classList.add('fade-in');

                // Special handling for views
                if(targetId === 'view-compare') {
                    updateCalculator(); // ensure chart renders correctly when unhidden
                }
            });
        });

        // --- Risks Tab Logic ---
        document.querySelectorAll('.risk-tab').forEach(tab => {
            tab.addEventListener('click', (e) => {
                document.querySelectorAll('.risk-tab').forEach(t => {
                    t.classList.remove('active', 'text-blue-600', 'border-b-2', 'border-blue-600');
                    t.classList.add('text-slate-500');
                });
                e.currentTarget.classList.add('active', 'text-blue-600', 'border-b-2', 'border-blue-600');
                e.currentTarget.classList.remove('text-slate-500');

                const targetId = e.currentTarget.getAttribute('data-target');
                document.querySelectorAll('.risk-content').forEach(c => c.classList.add('hidden'));
                document.getElementById(targetId).classList.remove('hidden');
            });
        });

        // --- Accordion Logic ---
        window.toggleDetails = function(id) {
            const el = document.getElementById(id);
            const icon = el.previousElementSibling.querySelector('.fa-chevron-down');
            if (el.classList.contains('hidden')) {
                el.classList.remove('hidden');
                icon.style.transform = 'rotate(180deg)';
            } else {
                el.classList.add('hidden');
                icon.style.transform = 'rotate(0deg)';
            }
        };

        // --- Checklist Logic ---
        window.toggleCheck = function(element) {
            const icon = element.querySelector('.check-icon');
            if (icon.classList.contains('fa-square')) {
                icon.classList.remove('fa-square', 'text-slate-400');
                icon.classList.add('fa-square-check', 'text-emerald-500');
            } else {
                icon.classList.add('fa-square', 'text-slate-400');
                icon.classList.remove('fa-square-check', 'text-emerald-500');
            }
        };

        // --- Calculator & Chart Logic ---
        let taxChart = null;
        let useBonus = true;

        const calcB2C = document.getElementById('calc-b2c');
        const calcB2B = document.getElementById('calc-b2b');
        const valB2C = document.getElementById('val-b2c');
        const valB2B = document.getElementById('val-b2b');
        const valTotal = document.getElementById('val-total');
        const limitWarning = document.getElementById('limit-warning');

        function formatCurrency(num) {
            return num.toLocaleString('ru-RU') + ' ₽';
        }

        document.querySelectorAll('.bonus-toggle').forEach(btn => {
            btn.addEventListener('click', (e) => {
                document.querySelectorAll('.bonus-toggle').forEach(b => {
                    b.classList.remove('active', 'bg-blue-100', 'text-blue-700', 'border-blue-200');
                    b.classList.add('bg-white', 'text-slate-600', 'border-slate-200');
                });
                e.target.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');
                e.target.classList.add('active', 'bg-blue-100', 'text-blue-700', 'border-blue-200');
                useBonus = e.target.getAttribute('data-val') === 'true';
                updateCalculator();
            });
        });

        [calcB2C, calcB2B].forEach(input => {
            input.addEventListener('input', () => {
                valB2C.textContent = formatCurrency(parseInt(calcB2C.value));
                valB2B.textContent = formatCurrency(parseInt(calcB2B.value));
                updateCalculator();
            });
        });

        function updateCalculator() {
            const incB2C = parseInt(calcB2C.value);
            const incB2B = parseInt(calcB2B.value);
            const total = incB2C + incB2B;

            valTotal.textContent = formatCurrency(total);

            // Limit check
            if (total > 2400000) {
                limitWarning.classList.remove('hidden');
                valTotal.classList.add('text-red-500');
            } else {
                limitWarning.classList.add('hidden');
                valTotal.classList.remove('text-red-500');
            }

            // Calculations
            // 1. NPD
            let taxNPD = 0;
            if (useBonus) {
                // Simplified bonus calculation logic (assuming 10k pool)
                // In reality, it deducts 1% from B2C and 2% from B2B until 10k is exhausted.
                let maxBonusB2C = incB2C * 0.01;
                let maxBonusB2B = incB2B * 0.02;
                let usedBonus = Math.min(10000, maxBonusB2C + maxBonusB2B);
                
                let baseTax = (incB2C * 0.04) + (incB2B * 0.06);
                taxNPD = baseTax - usedBonus;
                if(taxNPD < 0) taxNPD = 0;
            } else {
                taxNPD = (incB2C * 0.04) + (incB2B * 0.06);
            }

            // 2. IP USN 6%
            const fixedPayments = 57390; // Approx 2026
            const extra1Percent = total > 300000 ? (total - 300000) * 0.01 : 0;
            const totalInsurance = fixedPayments + extra1Percent;
            
            let taxUSN = total * 0.06;
            // USN allows deduction of insurance premiums (up to 100% for no employees)
            taxUSN = Math.max(0, taxUSN - totalInsurance); 
            
            const totalUSNBurden = taxUSN + totalInsurance;

            updateChart(taxNPD, totalUSNBurden, totalInsurance, taxUSN);
        }

        function updateChart(npd, usnTotal, usnIns, usnTax) {
            const ctx = document.getElementById('taxCompareChart').getContext('2d');
            
            if (taxChart) {
                taxChart.destroy();
            }

            taxChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Самозанятый (НПД)', 'ИП на УСН 6%'],
                    datasets: [
                        {
                            label: 'Налог',
                            data: [npd, usnTax],
                            backgroundColor: '#3B82F6', // Blue-500
                            borderRadius: 4
                        },
                        {
                            label: 'Обязательные взносы',
                            data: [0, usnIns],
                            backgroundColor: '#F59E0B', // Amber-500
                            borderRadius: 4
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.dataset.label + ': ' + formatCurrency(context.raw);
                                }
                            }
                        }
                    },
                    scales: {
                        x: { stacked: true },
                        y: { 
                            stacked: true,
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return value.toLocaleString() + ' ₽';
                                }
                            }
                        }
                    }
                }
            });
        }

        // Init
        updateCalculator();

    </script>
